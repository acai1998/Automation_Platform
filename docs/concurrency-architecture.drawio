        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 标题 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="title" value="自动化测试平台 — 并发执行控制架构甬道图" style="text;html=1;fontSize=22;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="1700" height="45" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="v1.4 · 2026-03-14 · 覆盖用例直接执行（run-case / run-batch）与任务调度两条路径" style="text;html=1;fontSize=13;align=center;fillColor=none;strokeColor=none;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="100" y="58" width="1700" height="28" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 泳道容器 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="pool" value="自动化测试平台 并发执行流程" style="shape=pool;startSize=40;horizontal=1;childLayout=stackLayout;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=0;marginBottom=0;fillColor=#f8f9fa;strokeColor=#aaa;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="1700" height="870" as="geometry" />
        </mxCell>

        <!-- 泳道1: 前端 -->
        <mxCell id="lane1" value="前端 (React / useTasks / useExecuteCase)" style="swimlane;startSize=50;horizontal=0;fillColor=#e8f4fd;strokeColor=#2196F3;fontStyle=1;fontSize=13;fontColor=#1565C0;" vertex="1" parent="pool">
          <mxGeometry x="0" y="0" width="1700" height="170" as="geometry" />
        </mxCell>

        <!-- 泳道2: API 网关层 -->
        <mxCell id="lane2" value="API 路由层 (server/routes/jenkins.ts)" style="swimlane;startSize=50;horizontal=0;fillColor=#fff3e0;strokeColor=#FF9800;fontStyle=1;fontSize=13;fontColor=#E65100;" vertex="1" parent="pool">
          <mxGeometry x="0" y="170" width="1700" height="200" as="geometry" />
        </mxCell>

        <!-- 泳道3: 调度器 -->
        <mxCell id="lane3" value="TaskSchedulerService (并发槽位控制核心)" style="swimlane;startSize=50;horizontal=0;fillColor=#f3e5f5;strokeColor=#9C27B0;fontStyle=1;fontSize=13;fontColor=#6A1B9A;" vertex="1" parent="pool">
          <mxGeometry x="0" y="370" width="1700" height="220" as="geometry" />
        </mxCell>

        <!-- 泳道4: 执行层 -->
        <mxCell id="lane4" value="ExecutionService + Jenkins (异步执行)" style="swimlane;startSize=50;horizontal=0;fillColor=#e8f5e9;strokeColor=#4CAF50;fontStyle=1;fontSize=13;fontColor=#1B5E20;" vertex="1" parent="pool">
          <mxGeometry x="0" y="590" width="1700" height="160" as="geometry" />
        </mxCell>

        <!-- 泳道5: 回调层 -->
        <mxCell id="lane5" value="回调处理层 (CallbackQueue + completeBatchExecution)" style="swimlane;startSize=50;horizontal=0;fillColor=#fce4ec;strokeColor=#E91E63;fontStyle=1;fontSize=13;fontColor=#880E4F;" vertex="1" parent="pool">
          <mxGeometry x="0" y="750" width="1700" height="120" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 泳道1 内容: 前端 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 路径A入口: 用例管理页"运行"按钮 -->
        <mxCell id="fe-run-btn" value="&lt;b&gt;用例管理页&lt;/b&gt;&lt;br&gt;点击「运行」/「批量运行」" style="rounded=1;whiteSpace=wrap;fillColor=#1565C0;fontColor=#fff;strokeColor=#0D47A1;fontSize=12;" vertex="1" parent="lane1">
          <mxGeometry x="60" y="60" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- 路径B入口: 任务管理页"立即执行" -->
        <mxCell id="fe-task-btn" value="&lt;b&gt;任务管理页&lt;/b&gt;&lt;br&gt;点击「立即执行」" style="rounded=1;whiteSpace=wrap;fillColor=#1565C0;fontColor=#fff;strokeColor=#0D47A1;fontSize=12;" vertex="1" parent="lane1">
          <mxGeometry x="900" y="60" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- 路径A hook -->
        <mxCell id="fe-hook-a" value="useExecuteCase&lt;br&gt;POST /api/jenkins/run-case&lt;br&gt;POST /api/jenkins/run-batch" style="rounded=1;whiteSpace=wrap;fillColor=#42A5F5;fontColor=#fff;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="lane1">
          <mxGeometry x="310" y="65" width="210" height="60" as="geometry" />
        </mxCell>

        <!-- 路径B hook -->
        <mxCell id="fe-hook-b" value="useTasks.useRunTask&lt;br&gt;POST /api/tasks/:id/run&lt;br&gt;(进入调度器 dispatchTask)" style="rounded=1;whiteSpace=wrap;fillColor=#42A5F5;fontColor=#fff;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="lane1">
          <mxGeometry x="1110" y="65" width="230" height="60" as="geometry" />
        </mxCell>

        <!-- 前端并发限制说明 -->
        <mxCell id="fe-note" value="前端 runWithConcurrencyLimit(3) 控制批量触发速率" style="shape=note;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="lane1">
          <mxGeometry x="560" y="60" width="260" height="70" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 泳道2 内容: API 路由层 -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- rate limiter -->
        <mxCell id="api-ratelimit" value="&lt;b&gt;Rate Limiter&lt;/b&gt;&lt;br&gt;generalAuthRateLimiter&lt;br&gt;+ rateLimitMiddleware" style="shape=mxgraph.flowchart.decision;whiteSpace=wrap;fillColor=#FF9800;fontColor=#fff;strokeColor=#E65100;fontSize=11;" vertex="1" parent="lane2">
          <mxGeometry x="60" y="60" width="160" height="100" as="geometry" />
        </mxCell>

        <!-- acquireDirectSlot -->
        <mxCell id="api-acquire" value="&lt;b&gt;acquireDirectSlot(label)&lt;/b&gt;&lt;br&gt;申请并发槽位&lt;br&gt;【NEW】槽位满则异步等待" style="rounded=1;whiteSpace=wrap;fillColor=#E65100;fontColor=#fff;strokeColor=#BF360C;fontSize=11;" vertex="1" parent="lane2">
          <mxGeometry x="270" y="55" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- 排队等待 decision -->
        <mxCell id="api-queue-decision" value="槽位是否可用？" style="shape=mxgraph.flowchart.decision;whiteSpace=wrap;fillColor=#FF9800;fontColor=#fff;strokeColor=#E65100;fontSize=11;" vertex="1" parent="lane2">
          <mxGeometry x="520" y="60" width="140" height="90" as="geometry" />
        </mxCell>

        <!-- 503 -->
        <mxCell id="api-503" value="队列已满&lt;br&gt;返回 503" style="rounded=1;whiteSpace=wrap;fillColor=#B71C1C;fontColor=#fff;strokeColor=#7F0000;fontSize=11;" vertex="1" parent="lane2">
          <mxGeometry x="525" y="155" width="130" height="40" as="geometry" />
        </mxCell>

        <!-- triggerTestExecution -->
        <mxCell id="api-trigger" value="triggerTestExecution()&lt;br&gt;创建 runId / executionId&lt;br&gt;写入 DB" style="rounded=1;whiteSpace=wrap;fillColor=#E65100;fontColor=#fff;strokeColor=#BF360C;fontSize=11;" vertex="1" parent="lane2">
          <mxGeometry x="710" y="55" width="190" height="80" as="geometry" />
        </mxCell>

        <!-- registerDirectSlot -->
        <mxCell id="api-register" value="&lt;b&gt;registerDirectSlot(runId, label)&lt;/b&gt;&lt;br&gt;注册槽位（持有到 Jenkins 回调/超时）&lt;br&gt;【NEW】" style="rounded=1;whiteSpace=wrap;fillColor=#E65100;fontColor=#fff;strokeColor=#BF360C;fontSize=11;" vertex="1" parent="lane2">
          <mxGeometry x="950" y="55" width="230" height="80" as="geometry" />
        </mxCell>

        <!-- 返回 200 -->
        <mxCell id="api-200" value="返回 200&lt;br&gt;{ runId, queueId, _concurrency }" style="rounded=1;whiteSpace=wrap;fillColor=#2E7D32;fontColor=#fff;strokeColor=#1B5E20;fontSize=11;" vertex="1" parent="lane2">
          <mxGeometry x="1240" y="65" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 泳道3 内容: 调度器 -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- runningSlots Map -->
        <mxCell id="sched-slots" value="&lt;b&gt;runningSlots&lt;/b&gt;&lt;br&gt;Map&lt;runId, RunningSlot&gt;&lt;br&gt;全局并发计数器&lt;br&gt;上限 = CONCURRENCY_LIMIT(3)" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;fillColor=#6A1B9A;fontColor=#fff;strokeColor=#4A148C;fontSize=11;" vertex="1" parent="lane3">
          <mxGeometry x="60" y="60" width="180" height="110" as="geometry" />
        </mxCell>

        <!-- directQueue -->
        <mxCell id="sched-dqueue" value="&lt;b&gt;directQueue[]&lt;/b&gt;&lt;br&gt;直连等待队列（FIFO）&lt;br&gt;run-case / run-batch 专用&lt;br&gt;上限 MAX_QUEUE_DEPTH(50)" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;fillColor=#7B1FA2;fontColor=#fff;strokeColor=#4A148C;fontSize=11;" vertex="1" parent="lane3">
          <mxGeometry x="290" y="60" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- waitQueue -->
        <mxCell id="sched-wqueue" value="&lt;b&gt;waitQueue[]&lt;/b&gt;&lt;br&gt;任务调度优先队列&lt;br&gt;manual(1) &gt; scheduled(2) &gt; retry(3)&lt;br&gt;上限 MAX_QUEUE_DEPTH(50)" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;fillColor=#7B1FA2;fontColor=#fff;strokeColor=#4A148C;fontSize=11;" vertex="1" parent="lane3">
          <mxGeometry x="540" y="60" width="210" height="110" as="geometry" />
        </mxCell>

        <!-- dispatchTask -->
        <mxCell id="sched-dispatch" value="&lt;b&gt;dispatchTask(taskId)&lt;/b&gt;&lt;br&gt;任务调度入口&lt;br&gt;槽位满 → waitQueue 入队&lt;br&gt;槽位空 → executeTask" style="rounded=1;whiteSpace=wrap;fillColor=#AB47BC;fontColor=#fff;strokeColor=#6A1B9A;fontSize=11;" vertex="1" parent="lane3">
          <mxGeometry x="800" y="60" width="210" height="100" as="geometry" />
        </mxCell>

        <!-- drainQueue -->
        <mxCell id="sched-drain" value="&lt;b&gt;drainQueue() + drainDirectQueue()&lt;/b&gt;&lt;br&gt;槽位释放后触发&lt;br&gt;同时唤醒两个队列的等待者" style="rounded=1;whiteSpace=wrap;fillColor=#AB47BC;fontColor=#fff;strokeColor=#6A1B9A;fontSize=11;" vertex="1" parent="lane3">
          <mxGeometry x="1060" y="60" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- releaseSlotByRunId -->
        <mxCell id="sched-release" value="&lt;b&gt;releaseSlotByRunId(runId)&lt;/b&gt;&lt;br&gt;Jenkins 回调/超时后&lt;br&gt;释放槽位" style="rounded=1;whiteSpace=wrap;fillColor=#AB47BC;fontColor=#fff;strokeColor=#6A1B9A;fontSize=11;" vertex="1" parent="lane3">
          <mxGeometry x="1360" y="60" width="210" height="80" as="geometry" />
        </mxCell>

        <!-- 超时自动释放说明 -->
        <mxCell id="sched-timeout-note" value="超时兜底：SLOT_HOLD_TIMEOUT_MS(30min)&lt;br&gt;防止 Jenkins 挂死永久占用槽位" style="shape=note;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="lane3">
          <mxGeometry x="1060" y="155" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 泳道4 内容: 执行层 -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- jenkinsService.triggerBatchJob -->
        <mxCell id="exec-jenkins" value="&lt;b&gt;jenkinsService.triggerBatchJob()&lt;/b&gt;&lt;br&gt;触发 Jenkins Job（异步）&lt;br&gt;传入 callbackUrl + scriptPaths" style="rounded=1;whiteSpace=wrap;fillColor=#2E7D32;fontColor=#fff;strokeColor=#1B5E20;fontSize=12;" vertex="1" parent="lane4">
          <mxGeometry x="200" y="50" width="260" height="80" as="geometry" />
        </mxCell>

        <!-- Jenkins -->
        <mxCell id="exec-jenkins-server" value="&lt;b&gt;Jenkins Server&lt;/b&gt;&lt;br&gt;运行 Python 测试脚本&lt;br&gt;（可能持续数分钟~数小时）" style="shape=mxgraph.cisco.servers.standard_server;whiteSpace=wrap;fillColor=#388E3C;fontColor=#fff;strokeColor=#1B5E20;fontSize=11;" vertex="1" parent="lane4">
          <mxGeometry x="560" y="40" width="160" height="100" as="geometry" />
        </mxCell>

        <!-- onBuildResolved -->
        <mxCell id="exec-build" value="onBuildResolved 回调&lt;br&gt;轮询 queueId → 获取 buildNumber&lt;br&gt;异步更新 DB buildId/buildUrl" style="rounded=1;whiteSpace=wrap;fillColor=#66BB6A;fontColor=#1B5E20;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="lane4">
          <mxGeometry x="790" y="50" width="230" height="80" as="geometry" />
        </mxCell>

        <!-- DB -->
        <mxCell id="exec-db" value="MySQL DB&lt;br&gt;Auto_BatchRunRecords&lt;br&gt;Auto_TestExecutions" style="shape=mxgraph.flowchart.database;whiteSpace=wrap;fillColor=#1B5E20;fontColor=#fff;strokeColor=#004D40;fontSize=11;" vertex="1" parent="lane4">
          <mxGeometry x="1100" y="40" width="160" height="100" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 泳道5 内容: 回调层 -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- POST /callback -->
        <mxCell id="cb-endpoint" value="POST /api/jenkins/callback&lt;br&gt;立即 ACK 202" style="rounded=1;whiteSpace=wrap;fillColor=#C2185B;fontColor=#fff;strokeColor=#880E4F;fontSize=11;" vertex="1" parent="lane5">
          <mxGeometry x="200" y="30" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- callbackQueue.enqueue -->
        <mxCell id="cb-queue" value="&lt;b&gt;callbackQueue.enqueue()&lt;/b&gt;&lt;br&gt;内存队列 + 单 Worker 串行消费&lt;br&gt;指数退避重试（最多 3 次）" style="rounded=1;whiteSpace=wrap;fillColor=#C2185B;fontColor=#fff;strokeColor=#880E4F;fontSize=11;" vertex="1" parent="lane5">
          <mxGeometry x="460" y="25" width="250" height="70" as="geometry" />
        </mxCell>

        <!-- completeBatchExecution -->
        <mxCell id="cb-complete" value="completeBatchExecution()&lt;br&gt;写入执行结果 + 更新状态" style="rounded=1;whiteSpace=wrap;fillColor=#E91E63;fontColor=#fff;strokeColor=#880E4F;fontSize=11;" vertex="1" parent="lane5">
          <mxGeometry x="770" y="30" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- releaseSlot call -->
        <mxCell id="cb-release" value="releaseSlotByRunId(runId)&lt;br&gt;【核心】释放并发槽位&lt;br&gt;触发后续任务执行" style="rounded=1;whiteSpace=wrap;fillColor=#880E4F;fontColor=#fff;strokeColor=#560027;fontSize=11;fontStyle=1;" vertex="1" parent="lane5">
          <mxGeometry x="1050" y="25" width="210" height="70" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 连线 - 路径A（用例直接执行） -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- 用例运行按钮 → hook -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1565C0;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="fe-run-btn" target="fe-hook-a" parent="lane1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- hook → rate limiter (跨泳道) -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2196F3;strokeWidth=2;dashed=1;" edge="1" parent="pool">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="415" y="130" as="sourcePoint" />
            <mxPoint x="145" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e2-label" value="POST run-case/run-batch" style="edgeLabel;fontSize=10;fillColor=#E3F2FD;strokeColor=none;" vertex="1" connectable="0" parent="e2">
