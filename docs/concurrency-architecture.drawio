<mxfile host="app.diagrams.net" modified="2026-03-14" version="21.0.0">
  <diagram name="并发控制架构甬道图" id="concurrency-swimlane">
    <mxGraphModel dx="1600" dy="960" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
