          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 连线 - 路径B（任务调度） -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- 任务按钮 → hook B -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1565C0;strokeWidth=2;" edge="1" source="fe-task-btn" target="fe-hook-b" parent="lane1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- hook B → dispatchTask (跨泳道) -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9C27B0;strokeWidth=2;dashed=1;" edge="1" parent="pool">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1225" y="160" as="sourcePoint" />
            <mxPoint x="900" y="440" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e12-label" value="POST /api/tasks/:id/run&lt;br&gt;→ dispatchTask()" style="edgeLabel;fontSize=10;fillColor=#F3E5F5;" vertex="1" connectable="0" parent="e12">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- dispatchTask → waitQueue -->
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9C27B0;strokeWidth=2;dashed=1;" edge="1" source="sched-dispatch" target="sched-wqueue" parent="lane3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13-label" value="槽位满入队" style="edgeLabel;fontSize=10;fillColor=#F3E5F5;" vertex="1" connectable="0" parent="e13">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- dispatchTask → runningSlots (直接) -->
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9C27B0;strokeWidth=2;" edge="1" source="sched-dispatch" target="sched-slots" parent="lane3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14-label" value="槽位空直接占用" style="edgeLabel;fontSize=10;fillColor=#F3E5F5;" vertex="1" connectable="0" parent="e14">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Jenkins → 回调 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E91E63;strokeWidth=2;" edge="1" parent="pool">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="640" y="750" as="sourcePoint" />
            <mxPoint x="305" y="820" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e15-label" value="执行完成&lt;br&gt;POST /callback" style="edgeLabel;fontSize=10;fillColor=#FCE4EC;" vertex="1" connectable="0" parent="e15">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- POST callback → enqueue -->
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2185B;strokeWidth=2;" edge="1" source="cb-endpoint" target="cb-queue" parent="lane5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- enqueue → completeBatchExecution -->
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C2185B;strokeWidth=2;" edge="1" source="cb-queue" target="cb-complete" parent="lane5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- completeBatchExecution → releaseSlot -->
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#880E4F;strokeWidth=3;" edge="1" source="cb-complete" target="cb-release" parent="lane5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- releaseSlot → releaseSlotByRunId (跨泳道) -->
        <mxCell id="e19" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9C27B0;strokeWidth=3;" edge="1" parent="pool">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1155" y="820" as="sourcePoint" />
            <mxPoint x="1465" y="650" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e19-label" value="releaseSlotByRunId(runId)&lt;br&gt;【核心：槽位释放时机后移】" style="edgeLabel;fontSize=10;fontStyle=1;fillColor=#EDE7F6;" vertex="1" connectable="0" parent="e19">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- releaseSlotByRunId → drainQueue -->
        <mxCell id="e20" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9C27B0;strokeWidth=2;" edge="1" source="sched-release" target="sched-drain" parent="lane3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e20-label" value="触发 drain" style="edgeLabel;fontSize=10;fillColor=#F3E5F5;" vertex="1" connectable="0" parent="e20">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- drain → directQueue (唤醒) -->
        <mxCell id="e21" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#AB47BC;strokeWidth=2;dashed=1;" edge="1" source="sched-drain" target="sched-dqueue" parent="lane3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e21-label" value="唤醒直连等待者" style="edgeLabel;fontSize=10;fillColor=#F3E5F5;" vertex="1" connectable="0" parent="e21">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- drain → waitQueue (唤醒) -->
        <mxCell id="e22" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#AB47BC;strokeWidth=2;dashed=1;" edge="1" source="sched-drain" target="sched-wqueue" parent="lane3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e22-label" value="唤醒任务等待者" style="edgeLabel;fontSize=10;fillColor=#F3E5F5;" vertex="1" connectable="0" parent="e22">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- Jenkins → DB (执行层内部) -->
        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#4CAF50;strokeWidth=2;" edge="1" source="exec-build" target="exec-db" parent="lane4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 图例 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="legend-bg" value="" style="rounded=1;fillColor=#FAFAFA;strokeColor=#aaa;" vertex="1" parent="1">
          <mxGeometry x="100" y="985" width="1700" height="80" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="图例" style="text;html=1;fontStyle=1;fontSize=13;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="120" y="990" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend1" value="路径 A：用例管理直接运行（run-case / run-batch）" style="rounded=1;fillColor=#E65100;fontColor=#fff;strokeColor=#BF360C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="993" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend2" value="路径 B：任务调度器执行（定时 / 手动触发）" style="rounded=1;fillColor=#7B1FA2;fontColor=#fff;strokeColor=#4A148C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="993" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend3" value="【NEW】本次新增的并发控制节点" style="rounded=1;fillColor=#880E4F;fontColor=#fff;strokeColor=#560027;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="880" y="993" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend4" value="虚线箭头 = 排队等待路径" style="rounded=1;fillColor=#F3E5F5;strokeColor=#9C27B0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="993" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend5" value="实线箭头 = 正常执行路径" style="rounded=1;fillColor=#E8F5E9;strokeColor=#4CAF50;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1400" y="993" width="200" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
