          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- acquireDirectSlot → decision -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E65100;strokeWidth=2;" edge="1" source="api-acquire" target="api-queue-decision" parent="lane2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- decision → 503 (队列满) -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#B71C1C;strokeWidth=2;" edge="1" source="api-queue-decision" target="api-503" parent="lane2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
