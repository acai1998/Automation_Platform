        </mxCell>

        <!-- acquireDirectSlot → directQueue (排队) -->
        <mxCell id="e6b" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9C27B0;strokeWidth=2;dashed=1;" edge="1" parent="pool">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="415" y="310" as="sourcePoint" />
            <mxPoint x="445" y="425" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e6b-label" value="槽位满则入队等待" style="edgeLabel;fontSize=10;fillColor=#F3E5F5;" vertex="1" connectable="0" parent="e6b">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- triggerTestExecution → registerDirectSlot -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E65100;strokeWidth=2;" edge="1" source="api-trigger" target="api-register" parent="lane2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- registerDirectSlot → 200 -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2E7D32;strokeWidth=2;" edge="1" source="api-register" target="api-200" parent="lane2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- registerDirectSlot → runningSlots (跨泳道) -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9C27B0;strokeWidth=2;" edge="1" parent="pool">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1065" y="360" as="sourcePoint" />
            <mxPoint x="155" y="435" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e9-label" value="注册 runningSlots" style="edgeLabel;fontSize=10;fillColor=#F3E5F5;" vertex="1" connectable="0" parent="e9">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- registerDirectSlot → triggerBatchJob (跨泳道) -->
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#4CAF50;strokeWidth=2;" edge="1" parent="pool">
