          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>

        <!-- decision → triggerTestExecution (槽位可用) -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2E7D32;strokeWidth=2;" edge="1" source="api-queue-decision" target="api-trigger" parent="lane2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6-label" value="槽位可用" style="edgeLabel;fontSize=10;fillColor=#E8F5E9;" vertex="1" connectable="0" parent="e6">
