{
  "extends": "../tsconfig.server.json",
  "include": [
    ".",
    "./**/*.ts",
    "../shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "compilerOptions": {
    "moduleResolution": "node",
    "skipLibCheck": true,
    "rootDir": "..",
    "forceConsistentCasingInFileNames": true,
    "typeRoots": [
      "./node_modules/@types",
      "../node_modules/@types"
    ],
    "types": ["node"]
  }
}
