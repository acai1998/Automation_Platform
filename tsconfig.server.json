{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist/server",
    "paths": {
      "@shared/*": [
        "./shared/*"
      ],
      "@configs/*": [
        "./configs/*"
      ],
      "@test/*": [
        "./test_case/*"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "server",
    "shared"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "archive",
    "tmp",
    ".aiconfig"
  ]
}